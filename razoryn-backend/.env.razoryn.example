# ──────────────────────────────────────────────────────────────────────────
# Razoryn deployment — environment template
#
# This is the SECOND deployment, running alongside Calibre. It is the SAME
# codebase; the only thing that makes it "the Razoryn app" is APP_BRAND=razoryn
# plus Razoryn's own credentials and its own database.
#
# Copy these into the Razoryn Railway service's Variables (do NOT commit real
# secrets). Calibre's service keeps its own separate copy with APP_BRAND=calibre.
# ──────────────────────────────────────────────────────────────────────────

# Brand selector — THIS is what makes it the Razoryn app. Must be exactly this.
APP_BRAND=razoryn

# Server
PORT=8080
NODE_ENV=production

# Postgres — Razoryn must have its OWN database, separate from Calibre.
# Railway injects DATABASE_URL automatically when you add a Postgres plugin.
DATABASE_URL=postgres://user:pass@host:5432/razoryn

# Auth — generate a long random string UNIQUE to this deployment.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-unique-per-deployment

# CORS — the public URL(s) this app is served from (comma-separated).
# Leave blank if frontend + backend are same-origin (the usual setup).
ALLOWED_ORIGINS=

# First-run admin seed — sets the initial admin password on a fresh database.
# After first login, change it in the app and you can remove this var.
SHOPIFY_INITIAL_ADMIN_PASSWORD=set-a-strong-initial-password

# ── eBay (Trading API — Auth'n'Auth) ───────────────────────────────────────
# Razoryn has ONE eBay store. brand.js maps it to the EBAY_AUTH_TOKEN var.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_AUTH_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_GB
EBAY_SITE_ID=3
EBAY_ENV=production

# ── Shopify (optional — product/stock sync) ────────────────────────────────
# Use Razoryn's OWN Shopify store + token, not Calibre's.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_LOCATION_ID=

# ── Competitor monitoring ──────────────────────────────────────────────────
# Reuses the eBay app credentials above (EBAY_APP_ID/EBAY_CERT_ID) to read
# competitors' public eBay listings via the Buy Browse API. Configure the actual
# competitor list (eBay usernames) in-app under the Competitors page — each
# deployment has its own DB, so Razoryn and Calibre keep separate lists.
COMPETITOR_SYNC_CRON=0 */6 * * *
COMPETITOR_UNDERCUT_PCT=5
COMPETITOR_DROP_PCT=10
COMPETITOR_NEW_ITEM_MAX=10
# Website scraping (Phase 2) — keep off until legally reviewed.
COMPETITOR_SCRAPE_ENABLED=false
COMPETITOR_USER_AGENT=RazorynWarehouseBot/1.0 (+https://razoryn.co.uk)
# Whole-market ranking + our own ad-rate formula (not eBay's inflated suggestion).
COMPETITOR_MARKET_CRON=30 4 * * *
COMPETITOR_MARKET_BATCH=25
COMPETITOR_AD_RATE_BASE=2
COMPETITOR_AD_RATE_MIN=1
COMPETITOR_AD_RATE_MAX=12
# Razoryn's own eBay seller username(s), so the market view highlights our listing.
OUR_EBAY_SELLERS=

# ---------- Invoice Hub integration ----------
# Forwards Razoryn's OWN direct bank-transfer and cash sales (and their refunds)
# into the Invoice Hub. eBay/Shopify/card(Stripe) are NOT pushed — reconciled by
# uploading those platforms' statements. INVOICE_HUB_SECRET = the Hub's
# INTEGRATION_WEBHOOK_SECRET. On Calibre's service set COMPANY="Calibre Auto Parts".
INVOICE_HUB_URL=https://razoryninvoice-production.up.railway.app
INVOICE_HUB_SECRET=
INVOICE_HUB_COMPANY=Razoryn EParts
