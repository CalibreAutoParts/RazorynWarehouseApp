# ── Shopify app (from Partner dashboard / `shopify app dev`) ─────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://your-tunnel-or-host
SCOPES=read_orders,read_products,write_products,read_inventory,read_customers

# ── Google Analytics 4 (Measurement Protocol) ──────────────────────────
# Admin → Data Streams → your stream → Measurement Protocol API secrets
GA4_MEASUREMENT_ID=G-XXXXXXX
GA4_API_SECRET=

# ── Meta (Conversions API) ─────────────────────────────────────────────
# Events Manager → Settings → Conversions API → generate access token
META_PIXEL_ID=
META_CAPI_TOKEN=
# Optional: test events code while validating in Events Manager
META_TEST_EVENT_CODE=

# ── eBay (Sell/Trading API for feedback sync) ──────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
EBAY_STORE_USERNAME=razoryneparts

# ── Email (back-in-stock + abandoned cart). Use any transactional API. ──
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=eparts@razoryn.co.uk

# ── DB (Prisma). SQLite for dev; Postgres URL for prod. ────────────────
DATABASE_URL="file:./dev.sqlite"
