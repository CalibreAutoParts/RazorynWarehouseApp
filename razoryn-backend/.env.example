# ==================== Razoryn Warehouse Backend ====================
# Copy this to `.env` for local dev. On Railway, set these in the
# service's Variables tab — DO NOT commit a real .env file.

# ---------- Core ----------
NODE_ENV=development
PORT=3000
# Long random string used to sign JWT auth tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string

# Origin allowed for cross-origin requests (e.g. https://warehouse.razoryn.co.uk)
# Leave blank in dev (frontend served by same Express)
CORS_ORIGIN=

# ---------- Database (Railway provides DATABASE_URL automatically when you
# attach a Postgres plugin; for local dev set your own) ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/razoryn_warehouse

# ---------- File uploads (Railway volume mount path) ----------
# In Railway, attach a volume to /data and set this to /data/uploads.
UPLOAD_DIR=./uploads

# ---------- Shopify ----------
# Create a custom app at:
#   https://admin.shopify.com/store/<your-store>/settings/apps/development
# Required scopes:
#   read_products, write_products, read_inventory, write_inventory,
#   read_orders, read_locations
SHOPIFY_STORE_DOMAIN=razoryn-eparts.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
# The Shopify location ID where this warehouse's stock is held.
# Get it via: GET /admin/api/2025-01/locations.json
SHOPIFY_LOCATION_ID=

# ---------- eBay ----------
# Generate at: https://developer.ebay.com/my/keys
# Use the User Token flow (Auth'n'Auth or OAuth — OAuth recommended).
EBAY_ENV=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
# Optional: marketplace and fulfillment policy IDs (UK = EBAY_GB)
EBAY_MARKETPLACE_ID=EBAY_GB

# ---------- Sync schedule ----------
# Cron expression for periodic Shopify/eBay polling.
# Default: every 5 minutes. Set to empty string to disable.
SYNC_CRON=*/5 * * * *

# ---------- Competitor monitoring ----------
# Scan configured competitors (eBay sellers; websites in Phase 2) for pricing,
# price-change history and new-item opportunities. Reuses the eBay app token.
# Cron expression — default every 6 hours. Set empty to disable.
COMPETITOR_SYNC_CRON=0 */6 * * *
# Alert thresholds (percentages):
COMPETITOR_UNDERCUT_PCT=5      # alert when a matched competitor is >=5% below us
COMPETITOR_DROP_PCT=10         # alert when a matched listing drops >=10%
COMPETITOR_NEW_ITEM_MAX=10     # cap new-opportunity alerts per scan
# Website scraping (Phase 2) — OFF by default; only enable after legal review.
COMPETITOR_SCRAPE_ENABLED=false
COMPETITOR_USER_AGENT=RazorynWarehouseBot/1.0 (+https://razoryn.co.uk)
# Whole-market ranking: daily snapshot of saturation + our eBay rank per matched part.
COMPETITOR_MARKET_CRON=30 4 * * *
COMPETITOR_MARKET_BATCH=25      # products snapshotted per market run
# Our OWN suggested ad-rate formula (we do NOT use eBay's inflated suggestion).
COMPETITOR_AD_RATE_BASE=2       # base ad rate %
COMPETITOR_AD_RATE_MIN=1        # floor %
COMPETITOR_AD_RATE_MAX=12       # ceiling %
# Our eBay seller usernames (comma-separated) so we highlight our own listings in
# the market ranking instead of treating ourselves as a rival. Optional.
OUR_EBAY_SELLERS=

# ---------- Demo / first-run ----------
# If true, /scripts/seed.js will load demo data on first migration.
SEED_ON_MIGRATE=true

# Initial admin account — created on first migration if no users exist.
INITIAL_ADMIN_EMAIL=ali@razoryn.co.uk
INITIAL_ADMIN_PASSWORD=changeme_now
INITIAL_ADMIN_PIN=9999
