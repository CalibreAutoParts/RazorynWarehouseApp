// Razoryn Ops data model. `Session` is the standard Shopify app template table;
// the rest power the dashboard, tracking funnel, and retention flows.
// SQLite for dev; switch provider to "postgresql" + DATABASE_URL for prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model OrderRecord {
  id           String   @id @default(cuid())
  shop         String
  orderId      String
  name         String?
  email        String?
  total        Int?     // pence
  vehicleReg   String?
  isLargePanel Boolean  @default(false)
  needsFitment Boolean  @default(false)
  fulfilled    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([shop, orderId])
  @@index([shop, needsFitment])
  @@index([shop, isLargePanel])
}

model BackInStockRequest {
  id         String    @id @default(cuid())
  shop       String
  email      String
  productId  String    // gid://shopify/Product/...
  variantId  String?
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?

  @@unique([email, productId], name: "email_productId")
  @@index([shop, productId, notifiedAt])
}

model AbandonedCheckout {
  id          String    @id @default(cuid())
  shop        String
  token       String    @unique
  email       String
  total       Int?
  recoveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TrackedEvent {
  id        String   @id @default(cuid())
  name      String
  clientId  String?
  value     Float?
  url       String?
  payload   String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}
