{
  "name": "razoryn-ops",
  "private": true,
  "version": "0.1.0",
  "description": "Custom Shopify app for Razoryn e-Parts: server-side tracking, orders + fitment dashboard, eBay→reviews sync, back-in-stock & abandoned-cart retention.",
  "type": "module",
  "scripts": {
    "dev": "shopify app dev",
    "build": "remix vite:build",
    "start": "remix-serve ./build/server/index.js",
    "deploy": "shopify app deploy",
    "config:link": "shopify app config link",
    "prisma": "prisma",
    "setup": "prisma generate && prisma migrate deploy",
    "sync:ebay": "node ./app/jobs/sync-ebay-reviews.server.js"
  },
  "dependencies": {
    "@remix-run/node": "^2.13.0",
    "@remix-run/react": "^2.13.0",
    "@remix-run/serve": "^2.13.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.5.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.0",
    "@prisma/client": "^5.20.0",
    "isbot": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.13.0",
    "@shopify/api-codegen-preset": "^1.1.1",
    "prisma": "^5.20.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20.10"
  }
}
