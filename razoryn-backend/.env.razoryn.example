# ──────────────────────────────────────────────────────────────────────────
# Razoryn deployment — environment template
#
# This is the SECOND deployment, running alongside Calibre. It is the SAME
# codebase; the only thing that makes it "the Razoryn app" is APP_BRAND=razoryn
# plus Razoryn's own credentials and its own database.
#
# Copy these into the Razoryn Railway service's Variables (do NOT commit real
# secrets). Calibre's service keeps its own separate copy with APP_BRAND=calibre.
# ──────────────────────────────────────────────────────────────────────────

# Brand selector — THIS is what makes it the Razoryn app. Must be exactly this.
APP_BRAND=razoryn

# Server
PORT=8080
NODE_ENV=production

# Postgres — Razoryn must have its OWN database, separate from Calibre.
# Railway injects DATABASE_URL automatically when you add a Postgres plugin.
DATABASE_URL=postgres://user:pass@host:5432/razoryn

# Auth — generate a long random string UNIQUE to this deployment.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-unique-per-deployment

# CORS — the public URL(s) this app is served from (comma-separated).
# Leave blank if frontend + backend are same-origin (the usual setup).
ALLOWED_ORIGINS=

# First-run admin seed — sets the initial admin password on a fresh database.
# After first login, change it in the app and you can remove this var.
SHOPIFY_INITIAL_ADMIN_PASSWORD=set-a-strong-initial-password

# ── eBay (Trading API — Auth'n'Auth) ───────────────────────────────────────
# Razoryn has ONE eBay store. brand.js maps it to the EBAY_AUTH_TOKEN var.
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_AUTH_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_GB
EBAY_SITE_ID=3
EBAY_ENV=production

# ── Shopify (optional — product/stock sync) ────────────────────────────────
# Use Razoryn's OWN Shopify store + token, not Calibre's.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01
SHOPIFY_LOCATION_ID=
