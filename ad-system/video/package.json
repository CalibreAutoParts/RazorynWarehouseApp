{
  "name": "razoryn-video",
  "version": "1.0.0",
  "private": true,
  "description": "Razoryn e-Parts — Remotion video templates (parts montage + webpage showcase)",
  "scripts": {
    "dev": "remotion studio",
    "render:parts": "remotion render PartsShowcase out/parts-showcase.mp4",
    "render:site": "remotion render SiteShowcase out/site-showcase.mp4",
    "render": "npm run render:parts && npm run render:site"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4"
  }
}
