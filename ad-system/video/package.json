{
  "name": "razoryn-video",
  "version": "1.0.0",
  "private": true,
  "description": "Razoryn e-Parts \u2014 Remotion video ad templates",
  "scripts": {
    "dev": "remotion studio",
    "render:all": "node render-all.mjs",
    "render:collections": "node render-collections.mjs",
    "render:order": "remotion render OrderStory out/promos/order-story.mp4",
    "render:price": "remotion render PriceReveal out/promos/price-reveal.mp4",
    "render:trade": "remotion render TradeAccount out/promos/trade-account.mp4",
    "render:fitment": "remotion render FitmentSupport out/promos/fitment-support.mp4",
    "render:dispatch": "remotion render SameDayDispatch out/promos/same-day-dispatch.mp4",
    "render:rhd": "remotion render RhdHeadlights out/promos/rhd-headlights.mp4",
    "render:ebay": "remotion render EbayTrust out/promos/ebay-trust.mp4",
    "render:genz": "remotion render GenZParts out/promos/genz-parts.mp4",
    "render:tiktok": "remotion render TikTokDeal out/tiktok/all.mp4",
    "render:parts": "remotion render PartsShowcase out/promos/parts-showcase.mp4",
